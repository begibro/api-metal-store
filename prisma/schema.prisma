generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  avatar    String?
  language  String   @default("uz")
  timezone  String   @default("Asia/Tashkent")
  createdAt DateTime @default(now())
}
